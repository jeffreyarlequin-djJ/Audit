{
  "manifest_version": 3,
  "name": "Swiss Telecom QA - Audit Tickets",
  "version": "1.0.0",
  "description": "Extension d'analyse qualite des tickets d'incident SAV Telephonie. Capturez le contenu d'une page ticket et lancez une analyse IA.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Swiss Telecom QA"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
